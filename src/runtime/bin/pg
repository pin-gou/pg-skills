#!/usr/bin/env python3
"""pg-skills CLI — minimal MVP (Phase 1 §1.4)

Subcommands:
    pg init              Ensure .pg/ structure + .opencode/ symlinks (idempotent, requires .pg/skills present)
    pg doctor            Validate .pg/ structure and project.yaml
    pg upgrade [version] Upgrade pg-skills (指定版本 tag 或默认 master)
    pg upgrade --list     Fetch remote tags, list available versions

Usage:
    python3 pg <subcommand> [options]
"""
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path

# ----- 默认 .gitignore 内容 (pg init 写入) -----

GITIGNORE_CONTENT = """\
# Runtime session directories (all auto-generated, never committed)
runs/
ad-hoc/
fix-issue/
agent/
regression/

# Dynamic generated files
*.profile
cronjobs/prompt.txt

# pg-init-project dynamic output (review-only, regenerated each run)
agents-md-patches.md

# Build artifacts within change sessions
changes/**/2-build/*.png
changes/**/2-build/*.txt
changes/**/*.log
"""

# ----- 路径解析 -----

def find_pg_skills_root() -> Path:
    """从本脚本位置反推 pg-skills 仓库根.

    Layout: pg-skills/src/runtime/bin/pg
            → parent (bin/) → parent (runtime/) → parent (src/) → parent (pg-skills/)
    """
    return Path(__file__).resolve().parent.parent.parent.parent


def find_project_root(start: Path | None = None) -> Path:
    """向上找项目根（包含 .pg/ 或常见标记）."""
    cur = (start or Path.cwd()).resolve()
    markers = ['.pg', 'package.json', 'pom.xml', 'go.mod', 'pyproject.toml']
    while cur != cur.parent:
        for m in markers:
            if (cur / m).exists():
                return cur
        cur = cur.parent
    return Path.cwd().resolve()


# ----- subcommand: init -----

def cmd_init(args) -> int:
    """初始化项目内的 pg-skills 目录结构.

    前提: .pg/skills/ 已被 git subtree 或手动方式同步进项目 (不是本命令的职责).

    本命令只做两件事, **全部幂等**, 可重复运行:
      1. 创建 .pg/{hooks,context,scripts,changes,runs}/ 目录结构
      2. 在 .opencode/agents/ / .opencode/commands/ / .opencode/skills/ 下
         为 .pg/skills/src/opencode/ 对应项创建 symlink

    业务配置 (.pg/project.yaml 真实内容 / .pg/hooks/ shell 脚本) 由
    pg-init-project SKILL 在 opencode 中扫描仓库后生成, 不在本命令职责内.
    """
    project_root = find_project_root()
    pg_dir = project_root / '.pg'
    pg_skills_root = find_pg_skills_root()
    version = (pg_skills_root / 'VERSION').read_text().strip()

    if not pg_dir.exists():
        print(f'ERROR: .pg/ not found at {pg_dir}.')
        print(f'  .pg/skills must be present before running pg init.')
        print(f'  If you have not yet synced pg-skills, run:')
        print(f'    git subtree add --prefix=.pg/skills pg-skills master --squash')
        return 1

    # 1. 创建目录结构 (exist_ok=True, 幂等)
    for sub in ['hooks', 'context', 'scripts', 'changes', 'runs']:
        (pg_dir / sub).mkdir(exist_ok=True)

    # 2. 初始化 .pg/.gitignore (仅在不存在时, 避免覆盖用户自定义)
    pg_gitignore = pg_dir / '.gitignore'
    if not pg_gitignore.exists():
        pg_gitignore.write_text(GITIGNORE_CONTENT)

    # 3. 生成 placeholder project.yaml (仅在不存在时, 避免覆盖 SKILL 已生成的)
    project_yaml = pg_dir / 'project.yaml'
    if not project_yaml.exists():
        project_yaml.write_text(generate_project_yaml(project_root))

    # 4. 创建 .opencode/ → .pg/skills/src/opencode/ 下的逐项 symlink
    if not args.no_symlinks:
        create_opencode_symlinks(project_root, pg_skills_root)

    # 5. 创建 pg-run symlink
    create_pg_run_symlink(project_root)

    print(f'✓ pg-skills init in {project_root}')
    print(f'  - pg-skills version: {version}')
    if not args.no_symlinks:
        print(f'  - .opencode/ symlinks ensured')
    print()
    print('Next steps:')
    print('  1. (重启 opencode 让 .opencode/ 下的 symlink 生效)')
    print('  2. 在 opencode 中输入：加载 pg-init-project skill')
    return 0


def create_opencode_symlinks(project_root: Path, pg_skills_root: Path) -> None:
    """在 .opencode/ 下创建逐项 symlink, 指向 .pg/skills/src/opencode/.

    Layout:
        .opencode/agents/   <--  .pg/skills/src/opencode/agents/   下每个文件/文件夹
        .opencode/commands/ <--  .pg/skills/src/opencode/commands/ 下每个文件
        .opencode/skills/   <--  .pg/skills/src/opencode/skills/   下每个文件夹
        (scripts/ 不创建 symlink)

    设计意图: 逐项 symlink 而非目录 symlink, 让用户能在 .opencode/ 下
    添加项目专属的 agents/commands/skills, 与 pg-skills 的版本并存.
    """
    opencode_dir = project_root / '.opencode'
    skills_root = pg_skills_root / 'src' / 'opencode'

    symlink_subdirs = ['agents', 'commands', 'skills']
    for sub in symlink_subdirs:
        target_dir = opencode_dir / sub
        src_dir = skills_root / sub
        if not src_dir.exists():
            print(f'  WARN: {src_dir} not found, skip')
            continue
        target_dir.mkdir(parents=True, exist_ok=True)

        current_names = {e.name for e in src_dir.iterdir()}
        for entry in sorted(src_dir.iterdir()):
            link = target_dir / entry.name
            rel_target = os.path.relpath(entry, start=target_dir)
            if link.is_symlink():
                if os.readlink(link) == rel_target:
                    continue
                link.unlink()
            elif link.exists():
                continue
            link.symlink_to(rel_target)
            print(f'  - symlink: .opencode/{sub}/{entry.name} → {rel_target}')

        for entry in sorted(target_dir.iterdir()):
            if entry.is_symlink() and entry.name not in current_names:
                raw = os.readlink(entry)
                if '.pg/skills' in raw:
                    entry.unlink()
                    print(f'  - removed stale: .opencode/{sub}/{entry.name}')


def create_pg_run_symlink(project_root: Path) -> None:
    """在项目根创建 pg-run symlink 指向 .pg/skills/src/runtime/bin/pg-run.

    幂等: 已存在且目标正确时跳过, 目标错误或为文件时覆盖.
    """
    link = project_root / 'pg-run'
    target = '.pg/skills/src/runtime/bin/pg-run'
    target_resolved = (project_root / target).resolve()
    if link.is_symlink():
        if link.resolve() == target_resolved:
            return
        link.unlink()
    elif link.exists():
        link.unlink()
    link.symlink_to(target)
    link.chmod(link.stat().st_mode | 0o111)
    print(f'  - symlink: pg-run → {target}')


def generate_project_yaml(project_root: Path) -> str:
    name = project_root.name
    return f"""# pg-skills project declaration
# Edit this file to declare your modules, environments, and tracks.
# Schema: pg-skills/src/runtime/spec/project.schema.json
#
# 注: 项目元信息 (项目名/语言) 暂存于 comment; schema 仅校验 SSOT 4 段.
# Phase 2 将扩展 schema 支持 project 顶层字段.
#
# init 模板包含一个 placeholder module 满足 schema 的 minProperties 约束.
# pg-init-project SKILL 扫描仓库后会用真实 module 替换整个 modules 段.
# placeholder 的 language 用 schema 允许的占位值 'python', 仅供 schema 校验通过,
# 实际项目语言由 SKILL 推断.

schema: spec-driven
# project: name={name}

modules:
  placeholder:
    root: .
    language: python
    description: "Placeholder module; replaced by pg-init-project SKILL."
environments:
  placeholder:
    description: "Placeholder env; replace after defining real envs."
    roles:
      placeholder:
        instances:
          - name: placeholder-1
            host: localhost
            port: 9999
tracks:
  placeholder:
    modules: [placeholder]
    max_fail_retries: 1
    max_fix_retries: 1
    description: "Placeholder track; replace after defining real modules."
stages:
  - name: placeholder
    tracks: [placeholder]
    gate: all_pass
    environment:
      required: false
    description: "Placeholder stage; replace after defining real modules."

fix_issue:
  max_iteration_count: 5
"""


# ----- subcommand: doctor -----

def cmd_doctor(args) -> int:
    project_root = find_project_root()
    pg_dir = project_root / '.pg'

    errors = []
    warnings = []
    ok_count = 0

    # 1. .pg/ 存在?
    if not pg_dir.exists():
        errors.append('.pg/ directory not found. Run: pg init')
    else:
        ok_count += 1

    # 2. .pg/project.yaml 存在?
    project_yaml = pg_dir / 'project.yaml'
    if not project_yaml.exists():
        errors.append('.pg/project.yaml not found')
    else:
        ok_count += 1
        # schema 校验
        try:
            validate_project_yaml(project_yaml, find_pg_skills_root() / 'src/runtime/spec/project.schema.json')
            ok_count += 1
            print(f'✓ .pg/project.yaml schema valid')
        except Exception as e:
            errors.append(f'.pg/project.yaml schema invalid: {e}')

    # 3. .pg/skills/VERSION 存在?
    pg_skills_root = find_pg_skills_root()
    version_file = pg_skills_root / 'VERSION'
    if not version_file.exists():
        errors.append('.pg/skills/VERSION not found')
    else:
        ok_count += 1
        current = version_file.read_text().strip()
        print(f'✓ pg-skills version: {current}')

    # 4. .pg/hooks/ 下文件可执行?
    hooks_dir = pg_dir / 'hooks'
    if hooks_dir.exists():
        for sh in hooks_dir.glob('*.sh'):
            if not os.access(sh, os.X_OK):
                warnings.append(f'.pg/hooks/{sh.name} not executable (chmod +x)')

    # 5. .pg/context/summary.yaml 存在?（如果声明了 context）
    summary = pg_dir / 'context' / 'summary.yaml'
    if not summary.exists():
        warnings.append('.pg/context/summary.yaml not found (optional but recommended)')

    # 6. .pg/hooks/lib/common.sh 存在? (pg_resolve_paths per-skill 路径路由)
    # 若 .pg/hooks/ 下有 hook 但缺 lib/common.sh, hook 走 $PG_LOG_FILE 单一日志,
    # pg-regression / pg-fix-issue 日志会回落到 scripts/logs 而非预期的
    # .pg/regression/<suite>/<env>-logs / .pg/fix-issue/<change>/<env>-logs
    if hooks_dir.exists():
        hook_files = list(hooks_dir.glob('*.sh'))
        lib_common = hooks_dir / 'lib' / 'common.sh'
        if hook_files and not lib_common.is_file():
            warnings.append(
                '.pg/hooks/lib/common.sh 不存在. role-* / env-* hook 无法调 '
                'pg_resolve_paths, pg-regression / pg-fix-issue 日志会回落到 '
                'scripts/logs. 修复: cp .pg/skills/examples/shell/hooks/lib/common.sh '
                '.pg/hooks/lib/common.sh'
            )
        elif lib_common.is_file():
            try:
                content = lib_common.read_text(encoding='utf-8')
                if 'pg_resolve_paths()' not in content:
                    warnings.append(
                        '.pg/hooks/lib/common.sh 存在但不含 pg_resolve_paths 函数. '
                        'SSOT 可能落后, 请同步: cp .pg/skills/examples/shell/hooks/lib/common.sh '
                        '.pg/hooks/lib/common.sh'
                    )
                else:
                    ok_count += 1
                    print('✓ .pg/hooks/lib/common.sh 含 pg_resolve_paths (per-skill 路径路由已启用)')
            except Exception as e:
                warnings.append(f'.pg/hooks/lib/common.sh 读失败: {e}')

    # 7. .pg/context/agent-protocol.md 存在? (pg-init-project Phase 5 产出)
    #    agent 拿 SSOT / 调 hook / 找日志的速查文件. 缺失说明 Phase 5 未跑,
    #    agent 可能用错入口 (如直接 bash .pg/hooks/... 而非 pg-invoke-hook.py).
    agent_protocol = pg_dir / 'context' / 'agent-protocol.md'
    if not agent_protocol.is_file():
        warnings.append(
            '.pg/context/agent-protocol.md 不存在. LLM agent 拿到任务时无 SSOT 速查, '
            '可能直接 bash .pg/hooks/... (审计不可见). 修复: 跑 pg-init-project (Phase 5 '
            '会自动生成), 或手动 cp .pg/skills/examples/shell/agent-protocol.md '
            '.pg/context/agent-protocol.md'
        )
    else:
        ok_count += 1
        print('✓ .pg/context/agent-protocol.md 存在 (agent SSOT 速查已就位)')

    # 8. 根 AGENTS.md 含 agent-protocol 引用? (pg-init-project Phase 5 联动检查)
    #    Phase 5 生成 agent-protocol.md 后, 必须有 AGENTS.md 引用它, 否则 agent 找不到.
    #    仅检查根 AGENTS.md (sub-module 的引用由各自维护, 不强制).
    root_agents_md = project_root / 'AGENTS.md'
    if root_agents_md.is_file():
        try:
            root_content = root_agents_md.read_text(encoding='utf-8')
            if 'agent-protocol' not in root_content:
                warnings.append(
                    '根 AGENTS.md 未引用 .pg/context/agent-protocol.md. LLM agent 看不到 '
                    'agent-protocol.md, 会回到"读 project.yaml / 直接 bash hook"的反模式. '
                    '修复: 在根 AGENTS.md 加一行"构建/启动/日志: 见 .pg/context/agent-protocol.md"'
                )
            else:
                ok_count += 1
                print('✓ 根 AGENTS.md 含 agent-protocol 引用 (Phase 5 双 SSOT 联动通过)')
        except Exception as e:
            warnings.append(f'根 AGENTS.md 读失败: {e}')

    # 输出
    print()
    if errors:
        print(f'ERRORS ({len(errors)}):')
        for e in errors:
            print(f'  ✗ {e}')
        return 1
    if warnings:
        print(f'WARNINGS ({len(warnings)}):')
        for w in warnings:
            print(f'  ⚠ {w}')
    print(f'OK ({ok_count} checks passed)')
    return 0


def validate_project_yaml(project_yaml: Path, schema_path: Path) -> None:
    """用 jsonschema 校验 project.yaml. 没有 jsonschema 时退化为最小校验."""
    try:
        import jsonschema  # type: ignore
        import yaml  # type: ignore
    except ImportError:
        # 最小校验: 必填字段存在
        import yaml  # type: ignore
        data = yaml.safe_load(project_yaml.read_text(encoding='utf-8'))
        for required in ['modules', 'environments', 'tracks', 'stages']:
            if required not in data:
                raise ValueError(f'missing required field: {required}')
        return

    import yaml  # type: ignore
    import jsonschema  # type: ignore
    schema = json.loads(schema_path.read_text(encoding='utf-8'))
    data = yaml.safe_load(project_yaml.read_text(encoding='utf-8'))
    jsonschema.validate(instance=data, schema=schema)


# ----- subcommand: upgrade (--list / --interactive / [version] 默认 master) -----

def cmd_upgrade(args) -> int:
    """Upgrade pg-skills via git subtree.

    Modes:
        --list:         Fetch remote tags, list available versions
        --interactive:  列出冲突文件, 让用户逐文件决策 (overwrite / keep-mine / abort)
        (默认):         执行 git subtree pull, 版本号自动补 v 前缀
    """
    project_root = find_project_root()
    pg_skills_root = find_pg_skills_root()
    current = (pg_skills_root / 'VERSION').read_text().strip()
    ref = _normalize_ref(args.version)

    if args.list:
        return _upgrade_check(project_root, current)

    if args.interactive:
        changed_files = _compute_changed_files(project_root, ref)
        return _upgrade_interactive(project_root, pg_skills_root, current, ref, changed_files)

    return _upgrade_pull(project_root, current, ref, args.force)


def _normalize_ref(version: str | None) -> str:
    if version is None:
        return 'master'
    if re.fullmatch(r'\d+(\.\d+)*', version):
        return f'v{version}'
    return version


def _to_tag_ref(ref: str) -> str:
    if bool(re.match(r'^v?\d+\.\d+', ref)):
        return f'refs/tags/{ref}'
    return ref


def _upgrade_check(project_root: Path, current: str) -> int:
    """Fetch remote tags, 列出可用版本."""
    remote = 'pg-skills'
    check = subprocess.run(
        ['git', '-C', str(project_root), 'remote', 'get-url', remote],
        capture_output=True, text=True,
    )
    if check.returncode != 0:
        print(f'ERROR: remote "{remote}" not configured.')
        print(f'  Run: git remote add {remote} git@github.com:pin-gou/pg-skills.git')
        return 1

    subprocess.run(
        ['git', '-C', str(project_root), 'fetch', remote, '--tags'],
        capture_output=True, text=True,
    )

    result = subprocess.run(
        ['git', '-C', str(project_root), 'tag', '-l', 'v*'],
        capture_output=True, text=True,
    )
    tags = [t for t in result.stdout.strip().split('\n') if t]

    current_tag = f'v{current}' if not current.startswith('v') else current
    print(f'Current: {current_tag}')
    for t in sorted(tags):
        marker = '  ← current' if t == current_tag else ''
        print(f'  {t}{marker}')
    return 0


def _compute_changed_files(project_root: Path, ref: str) -> list:
    """Fetch remote ref 并计算 .pg/skills/ 差异."""
    remote = 'pg-skills'
    fetch_ref = _to_tag_ref(ref)
    subprocess.run(
        ['git', '-C', str(project_root), 'fetch', remote, fetch_ref],
        capture_output=True, text=True,
    )
    result = subprocess.run(
        ['git', '-C', str(project_root), 'diff', '--name-only', 'FETCH_HEAD', '--', '.pg/skills/'],
        capture_output=True, text=True,
    )
    return [f for f in result.stdout.strip().split('\n') if f]


def _upgrade_pull(project_root: Path, current: str, ref: str, force: bool = False) -> int:
    """Upgrade pg-skills.

    --force: clone-to-temp + 覆盖复制 (绕过 git subtree, 脏树健壮)
    非 force: git subtree pull (要求干净工作树)
    """
    remote = 'pg-skills'
    prefix = '.pg/skills'

    check = subprocess.run(
        ['git', '-C', str(project_root), 'remote', 'get-url', remote],
        capture_output=True, text=True,
    )
    if check.returncode != 0:
        print(f'ERROR: remote "{remote}" not configured.')
        print(f'  Run: git remote add {remote} https://github.com/pin-gou/pg-skills.git')
        print(f'  Run: git fetch {remote}')
        return 1

    if force:
        return _upgrade_by_copy(project_root, project_root / prefix, ref)

    status = subprocess.run(
        ['git', '-C', str(project_root), 'status', '--porcelain'],
        capture_output=True, text=True,
    )
    if status.stdout.strip():
        print('ERROR: Working tree has modifications. Run with --force to overwrite.')
        return 1

    subtree_ref = _to_tag_ref(ref)
    if not (project_root / prefix).exists():
        print(f'INFO: {prefix}/ not found, performing initial subtree add')
        cmd = ['git', 'subtree', 'add', f'--prefix={prefix}', remote, subtree_ref, '--squash']
    else:
        cmd = ['git', 'subtree', 'pull', f'--prefix={prefix}', remote, subtree_ref, '--squash']

    print(f'Running: {" ".join(cmd)}')
    result = subprocess.run(cmd, cwd=str(project_root), text=True)
    if result.returncode != 0:
        print(f'ERROR: git subtree failed (exit {result.returncode})')
        print(f'  Try: pg upgrade --force')
        return 1

    pg_skills_root = find_pg_skills_root()
    new_version = (pg_skills_root / 'VERSION').read_text().strip()

    create_opencode_symlinks(project_root, pg_skills_root)
    create_pg_run_symlink(project_root)

    print(f'✓ pg-skills {current} → {new_version}: {n_changed(project_root)} files updated')
    return 0


def _upgrade_by_copy(project_root: Path, pg_skills_dir: Path, ref: str) -> int:
    """Clone target ref to temp dir → 覆盖复制到 .pg/skills/.

    绕过 git subtree, 兼容脏工作树.
    """
    from datetime import datetime
    import shutil
    import tempfile

    remote_https = f'https://github.com/pin-gou/pg-skills.git'
    remote_ssh = f'git@github.com:pin-gou/pg-skills.git'

    # 1. 备份现有 .pg/skills/
    backup_dir = None
    if pg_skills_dir.exists():
        ts = datetime.now().strftime('%Y%m%d%H%M%S')
        backup_dir = project_root / f'.pg/skills.backup.{ts}'
        print(f'Backing up existing {pg_skills_dir} to {backup_dir} ...')
        shutil.copytree(pg_skills_dir, backup_dir)

    # 2. Clone 到临时目录
    tmp_dir = Path(tempfile.mkdtemp(prefix='pg-upgrade-'))
    clone_ref = ref
    print(f'Cloning {remote_https} ({clone_ref}) ...')
    clone_result = subprocess.run(
        ['git', 'clone', '--depth=1', '--branch', clone_ref, remote_https, str(tmp_dir)],
        capture_output=True, text=True, timeout=120,
    )
    if clone_result.returncode != 0:
        print(f'  https failed, trying ssh ...')
        clone_result = subprocess.run(
            ['git', 'clone', '--depth=1', '--branch', clone_ref, remote_ssh, str(tmp_dir)],
            capture_output=True, text=True, timeout=120,
        )
    if clone_result.returncode != 0:
        print(f'ERROR: clone failed: {clone_result.stderr.strip()[-300:]}')
        if backup_dir and backup_dir.exists():
            print(f'  Backup preserved at {backup_dir}, restore manually.')
        shutil.rmtree(tmp_dir, ignore_errors=True)
        return 1

    # 3. 删除旧 .pg/skills/ → 复制新文件
    if pg_skills_dir.exists() or pg_skills_dir.is_symlink():
        if pg_skills_dir.is_symlink():
            pg_skills_dir.unlink()
        else:
            shutil.rmtree(pg_skills_dir)
    print(f'Copying files to .pg/skills/ ...')
    shutil.copytree(tmp_dir, pg_skills_dir, ignore=shutil.ignore_patterns('.git'))

    # 4. 清理临时目录
    shutil.rmtree(tmp_dir, ignore_errors=True)

    # 5. 刷新 symlinks
    create_opencode_symlinks(project_root, pg_skills_dir)
    create_pg_run_symlink(project_root)

    new_version = (pg_skills_dir / 'VERSION').read_text().strip()
    print(f'✓ pg-skills upgraded to {new_version} (by copy, {ref})')

    # 6. 提示备份
    if backup_dir and backup_dir.exists():
        print(f'  ⚠ Backup preserved at {backup_dir}')
        print(f'    如需本地修改请自行还原：rm -rf .pg/skills && mv {backup_dir} .pg/skills')

    return 0


def _upgrade_interactive(project_root: Path, pg_skills_root: Path, current: str, ref: str, changed_files: list) -> int:
    """dry-run diff, 列出冲突文件, 让用户逐文件决策."""
    if not changed_files:
        print(f'No file changes detected between current and {ref}')
        return 0

    print(f'pg-skills {current} → {ref}')
    print(f'  Files that would change ({len(changed_files)}):')
    for f in changed_files[:20]:
        print(f'    - {f}')
    if len(changed_files) > 20:
        print(f'    ... and {len(changed_files) - 20} more')

    # 检查本地修改
    has_local = False
    for f in changed_files:
        local = project_root / '.pg/skills' / f
        if local.exists():
            status = subprocess.run(
                ['git', '-C', str(project_root), 'status', '--porcelain', str(local)],
                capture_output=True, text=True,
            )
            if status.stdout.strip():
                has_local = True
                break

    if has_local:
        print('\n⚠ WARNING: Local changes detected in .pg/skills/ that conflict with upstream.')
        print('  Recommend: keep-mine for files you have customized, overwrite for the rest.')
        print('  Run: pg upgrade    (with default keep-mine strategy)')

    print(f'\nTo upgrade: pg upgrade')
    return 0


def n_changed(project_root: Path) -> int:
    """数最新一次 commit 改了 .pg/skills/ 几个文件."""
    result = subprocess.run(
        ['git', '-C', str(project_root), 'diff', '--name-only', 'HEAD~1', 'HEAD', '--', '.pg/skills/'],
        capture_output=True, text=True,
    )
    files = [f for f in result.stdout.strip().split('\n') if f]
    return len(files)


# ----- main -----

def main():
    parser = argparse.ArgumentParser(prog='pg', description='pg-skills CLI')
    subparsers = parser.add_subparsers(dest='subcommand', required=True)

    # init
    p_init = subparsers.add_parser('init', help='Initialize .pg/ in current project (idempotent)')
    p_init.add_argument('--no-symlinks', action='store_true', help='Skip .opencode/ symlink creation')
    p_init.set_defaults(func=cmd_init)

    # doctor
    p_doctor = subparsers.add_parser('doctor', help='Validate .pg/ structure')
    p_doctor.set_defaults(func=cmd_doctor)

    # upgrade (--list / --interactive / [version] 默认 master)
    p_upgrade = subparsers.add_parser('upgrade', help='Upgrade pg-skills via git subtree')
    p_upgrade.add_argument('version', nargs='?', default=None,
                           help='Version tag to upgrade to (e.g., 0.2.0). Default: master')
    p_upgrade.add_argument('--list', action='store_true', help='Fetch remote tags, list available versions')
    p_upgrade.add_argument('--interactive', action='store_true', help='Show conflict files before upgrade')
    p_upgrade.add_argument('--force', action='store_true', help='Stash working tree modifications before pull')
    p_upgrade.set_defaults(func=cmd_upgrade)

    args = parser.parse_args()
    sys.exit(args.func(args))


if __name__ == '__main__':
    main()
