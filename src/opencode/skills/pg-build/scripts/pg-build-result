#!/usr/bin/env python3
"""pg-build-result — sub-agent 返回契约校验与生成工具 (v2.1 新增)。

双模式：

  --mode agent   : sub-agent 在返回前调用，输出完整 JSON 结构供 sub-agent 直接复制到返回值
  --mode runner  : 编排器 LLM 在调 `pg-pipeline-runner.py record` 前调用，
                   输出可直接拼到 record 命令后的 CLI 参数字符串

两种模式都通过 sub_agent_contract.validate_record_args 校验字段，校验失败 exit 1。

v2.4 新增（sub-agent 返回契约强制落盘）：

  --output-path <path> : 可选。指定后，脚本会将生成的 JSON 同时写入该绝对路径文件，
                         并在写入后 `cat` 文件内容到 stdout 供 sub-agent 验证。
                         文件路径通常由 dispatch_file 同前缀派生：
                         e.g. <seq>-<track>-<phase>.result.json

  --require-output     : 可选。配合 --output-path 使用；若文件未写入成功则 exit 1。
                         推荐编排器在 dispatch 阶段强制设置此标志。

用法（agent 模式）：
    pg-build-result --mode agent \\
        --status pass \\
        --summary "8/9 检查通过, gate_score: 91, p0_failures: []" \\
        --track dev.frontend --phase gate \\
        --evidence /abs/049-evidence.md \\
        --report /abs/051-gate.md \\
        --outputs /abs/out1.java,/abs/out2.java \\
        --output-path /abs/051-dev.frontend-gate.result.json \\
        --require-output

用法（runner 模式）：
    pg-build-result --mode runner --status pass --summary "..." ...

退出码：
    0  — 校验通过，输出 JSON 或 CLI 参数字符串到 stdout
    1  — 校验失败，错误信息到 stderr
    2  — --require-output 时文件未写入（v2.4 新增）
"""
from __future__ import annotations

import argparse
import json
import os
import sys
from typing import Any

# 让脚本能从任意 cwd 调用
_THIS_DIR = os.path.dirname(os.path.abspath(__file__))
if _THIS_DIR not in sys.path:
    sys.path.insert(0, _THIS_DIR)

from pipeline.sub_agent_contract import validate_record_args  # noqa: E402


def _parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        prog="pg-build-result",
        description="Sub-agent 返回契约校验与生成工具 (v2.4)",
    )
    p.add_argument(
        "--mode", choices=["agent", "runner"], required=True,
        help="agent=sub-agent 返回前; runner=编排器 record 前",
    )
    p.add_argument("--status", required=True,
                   help="record status: completed|failed|escalate|pass|fail")
    p.add_argument("--summary", required=True, help="一句话摘要（<=200 字）")
    p.add_argument("--track", required=True, help="如 dev.backend")
    p.add_argument("--phase", required=True,
                   help="test|dev|verify|gate|fix|fix-gate|simple")
    p.add_argument("--report", default="", help="报告路径（verify/gate 必须）")
    p.add_argument(
        "--evidence", action="append", default=[],
        help="证据文件路径（可多次传）",
    )
    p.add_argument(
        "--outputs", default="",
        help="产物文件列表，逗号分隔",
    )
    p.add_argument("--issues", default="", help="问题列表，逗号分隔")
    p.add_argument(
        "--tasks-updated", action="append", default=[],
        help="task_id 列表（可多次传：--tasks-updated 1.1 --tasks-updated 2.1）"
    )
    # ── v2.7 新增：design.md fault 标记 ──
    p.add_argument(
        "--design-md-fault", action="store_true", default=False,
        help="v2.7: fix-review 检测到 design.md 文档层缺陷，无法由代码修复",
    )
    p.add_argument(
        "--design-md-fault-location", default="",
        help="v2.7: 文档缺陷位置 (file:line)",
    )
    # ── v3.x 新增：design drift 标记 ──
    p.add_argument(
        "--design-drift", default="",
        help="v3.x: scenario-fix 检测到的 design 偏移，JSON 格式。"
             "例: '{\"phase\": \"scenario-execute\", \"location\": \"ProjectResponse 缺 network\"}'",
    )
    # ── v2.4 新增：强制落盘参数 ──
    p.add_argument(
        "--output-path", default="",
        help="v2.4: 将生成的 JSON 同时写入此绝对路径文件。"
             "典型用法：与 dispatch_file 同前缀的 .result.json。",
    )
    p.add_argument(
        "--require-output", action="store_true",
        help="v2.4: 若 --output-path 指定但文件未写入成功则 exit 2。"
             "编排器在 dispatch 阶段强制设置此标志。",
    )
    return p.parse_args(argv)


def _validate(args: argparse.Namespace) -> tuple[bool, str]:
    """委托 sub_agent_contract 校验。"""
    return validate_record_args(
        phase=args.phase,
        track=args.track,
        status=args.status,
        summary=args.summary,
        report_path=args.report,
        outputs=args.outputs,
        issues=args.issues,
        evidence_paths=tuple(args.evidence),
        tasks_updated=tuple(args.tasks_updated),
    )


def _build_result_dict(args: argparse.Namespace) -> dict[str, Any]:
    """构造 sub-agent 返回的 JSON dict。"""
    result = {
        "summary": args.summary,
        "outputs": [s.strip() for s in args.outputs.split(",") if s.strip()],
        "tasks_updated": list(args.tasks_updated),
        "status": args.status,
        "evidence_paths": list(args.evidence),
        "report_path": args.report,
    }
    # v2.7: design.md fault 标记
    if args.design_md_fault:
        result["design_md_fault"] = True
        if args.design_md_fault_location:
            result["design_md_fault_location"] = args.design_md_fault_location
    # v3.x: design drift 标记
    if args.design_drift:
        try:
            import json as _json
            drift = _json.loads(args.design_drift)
            result["design_drift"] = drift
        except (json.JSONDecodeError, TypeError):
            pass
    return result


def _write_output_file(args: argparse.Namespace, result: dict[str, Any]) -> tuple[bool, str]:
    """v2.4 新增：将 JSON 写入 --output-path 指定路径。

    Returns:
        (ok, error_msg): ok=True 表示写入成功
    """
    if not args.output_path:
        return True, ""

    try:
        os.makedirs(os.path.dirname(os.path.abspath(args.output_path)), exist_ok=True)
        with open(args.output_path, "w", encoding="utf-8") as f:
            json.dump(result, f, ensure_ascii=False, indent=2)
    except OSError as e:
        return False, f"无法写入 {args.output_path}: {e}"

    # 验证文件确实落盘（防止缓存/磁盘问题）
    if not os.path.isfile(args.output_path):
        return False, f"写入后文件仍不存在: {args.output_path}"

    return True, ""


def _emit_agent_mode(args: argparse.Namespace) -> int:
    """输出完整 JSON 结构供 sub-agent 复制到返回值。"""
    result = _build_result_dict(args)

    # v2.4: 强制落盘
    if args.output_path or args.require_output:
        ok, err = _write_output_file(args, result)
        if not ok:
            print(f"[pg-build-result] 写入失败:\n  {err}", file=sys.stderr)
            return 2  # v2.4: 专用退出码
        # 写盘后回声到 stderr：让 sub-agent 看到自己写入的内容（防止幻觉）
        with open(args.output_path, encoding="utf-8") as f:
            echo_content = f.read()
        print(f"[pg-build-result] 已落盘到 {args.output_path}", file=sys.stderr)
        print(echo_content, file=sys.stderr)
        # ORCHESTRATOR_READY 标记写到 stderr（不污染 stdout JSON）
        print("**ORCHESTRATOR_READY**", file=sys.stderr)

    # stdout 仅输出 JSON（保持 v2.3 兼容）
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


def _emit_runner_mode(args: argparse.Namespace) -> int:
    """输出可直接拼到 `runner record <change>` 命令后的 CLI 参数字符串。"""
    parts: list[str] = [f"--status {args.status}"]
    if args.report:
        parts.append(f"--report {args.report}")
    parts.append(f"--summary \"{args.summary}\"")
    if args.outputs:
        parts.append(f"--outputs {args.outputs}")
    if args.issues:
        parts.append(f"--issues {args.issues}")
    if args.design_md_fault:
        parts.append("--design-md-fault")
        if args.design_md_fault_location:
            parts.append(f"--design-md-fault-location \"{args.design_md_fault_location}\"")
    # runner record CLI: <change> --status <status> [--report <path>] [--summary <文本>] ...
    # 这里只输出 --status 之后的参数；编排器需要自行加上 change
    print(" ".join(p for p in parts))
    return 0


def main() -> int:
    args = _parse_args(sys.argv[1:])
    ok, reason = _validate(args)
    if not ok:
        print(f"[pg-build-result] 校验失败:\n  {reason}", file=sys.stderr)
        print(
            "\n[pg-build-result] 提示: 修复参数后重试。"
            " 字段约束见 sub_agent_contract.py 模块。",
            file=sys.stderr,
        )
        return 1
    if args.mode == "agent":
        return _emit_agent_mode(args)
    return _emit_runner_mode(args)


if __name__ == "__main__":
    sys.exit(main())