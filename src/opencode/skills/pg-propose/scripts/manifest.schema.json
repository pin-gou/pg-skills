{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Manifest",
  "description": "Pipeline execution manifest generated by pg-gen-manifest.py from tasks.md + project.yaml",
  "type": "object",
  "required": ["schema_version", "change", "stages"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of the manifest format",
      "enum": ["2026-06-30"]
    },
    "change": {
      "type": "string",
      "description": "Change name matching the directory in .pg/changes/<change>/"
    },
    "stages": {
      "type": "array",
      "description": "Ordered list of stages to execute (in order)",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "environment", "tracks"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Stage name matching project.yaml stages[].name"
          },
          "environment": {
            "type": "string",
            "description": "Environment name matching project.yaml environments.<env>",
            "minLength": 1
          },
          "tracks": {
            "type": "array",
            "description": "Tracks to execute within this stage (in order)",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "type"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Track ID matching project.yaml tracks.<id>"
                },
                "type": {
                  "type": "string",
                  "enum": ["standard", "simple"],
                  "description": "standard = TDVG sub-agent sequence; simple = commands-only"
                },
                "phase_prompts": {
                  "type": "object",
                  "description": "Required for standard tracks: maps each sub-phase to its tasks.md section",
                  "minProperties": 4,
                  "maxProperties": 4,
                  "required": ["test", "dev", "verify", "gate"],
                  "additionalProperties": false,
                  "properties": {
                    "test":   { "$ref": "#/$defs/phase_prompt" },
                    "dev":    { "$ref": "#/$defs/phase_prompt" },
                    "verify": { "$ref": "#/$defs/phase_prompt" },
                    "gate":   { "$ref": "#/$defs/phase_prompt" }
                  }
                },
                "commands": {
                  "type": "array",
                  "description": "Required for simple tracks: list of commands to execute",
                  "items": { "type": "string" },
                  "minItems": 1
                }
              }
            },
            "allOf": [
              {
                "if": { "properties": { "type": { "const": "standard" } } },
                "then": { "required": ["phase_prompts"] }
              },
              {
                "if": { "properties": { "type": { "const": "simple" } } },
                "then": { "required": ["commands"] }
              }
            ]
          }
        }
      }
    },
    "final_gate": {
      "type": "object",
      "description": "Optional final-gate section reference",
      "required": ["tasks_md_section"],
      "additionalProperties": false,
      "properties": {
        "tasks_md_section": {
          "type": "string",
          "description": "Full heading text (after '## ') of the final-gate section in tasks.md"
        }
      }
    }
  },
  "$defs": {
    "phase_prompt": {
      "type": "object",
      "required": ["tasks_md_section"],
      "additionalProperties": false,
      "properties": {
        "tasks_md_section": {
          "type": "string",
          "description": "Full heading text (after '## ') identifying the section in tasks.md"
        }
      }
    }
  }
}